{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/ai-chat",
      "destination": "https://honkoma-ai-chat.quickclip.workers.dev/api/ai-chat"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
